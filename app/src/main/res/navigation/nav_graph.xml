<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/cameraFragment">

    <fragment
        android:id="@+id/cameraFragment"
        android:name="com.capstone.matengga.ui.camera.CameraFragment"
        android:label="CameraFragment">
        <action
            android:id="@+id/action_camera_to_result"
            app:destination="@id/resultFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.capstone.matengga.ui.result.ResultFragment"
        android:label="ResultFragment" />

    <fragment
        android:id="@+id/emptyFragment"
        android:name="com.capstone.matengga.ui.result.EmptyFragment"
        android:label="EmptyFragment" />

</navigation>